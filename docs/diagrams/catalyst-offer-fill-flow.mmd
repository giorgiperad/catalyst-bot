flowchart TB
    CS["Coinset.org"] -->|pending spends| MW["Mempool watcher"]
    MW -->|fill signal| BL["Bot Loop"]

    BL -->|create / cancel / requote| OM["Offer Manager"]
    CM["Coin Manager"] -->|coins + fees| OM
    RM["Risk Manager"] -->|spread + skew| OM

    OM -->|wallet offers| W["Sage wallet RPC"]
    OM -->|offer state| DB[("SQLite WAL state")]
    OM -->|bech32| DM["Dexie Manager"]
    OM -->|bech32| SM["Splash Manager"]

    DM -->|post + IDs| DX["Dexie"]
    SM -->|broadcast offers| SP["Splash P2P"]
    SP -->|peer offers| SR["Splash receive listener"]
    SR -->|inbound offers| DB

    W -->|offer status| FT["Fill Tracker"]
    DX -->|terminal status| FT
    SC["Spacescan"] -->|on-chain check| FT
    FT -->|fills + PnL| DB
    FT -->|fill event| BL
    DB -->|inventory| RM
