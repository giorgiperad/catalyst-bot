# ============================================================
# Chia Market Maker — Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# Do NOT use quotes around values (the config loader strips them,
# but surrounding quotes can cause issues on some systems).
#
# SECURITY: Keep your .env file private. Never commit it to git.
# ============================================================


# ============================================================
# WALLET BACKEND
# ============================================================
# "sage"  = Sage light wallet (recommended, no full node needed)
# "chia"  = Official Chia wallet (requires full node)
WALLET_TYPE=sage


# ============================================================
# SAGE WALLET (if WALLET_TYPE=sage)
# ============================================================
# Use 127.0.0.1 (not localhost) on Windows. Sage binds IPv4-only,
# and Python's getaddrinfo on Windows prefers IPv6 [::1], which causes
# every RPC call to stall in SYN_SENT until it falls back to IPv4.
SAGE_RPC_URL=https://127.0.0.1:9257
SAGE_CERT_PATH=
SAGE_KEY_PATH=
SAGE_EXE_PATH=
SAGE_FINGERPRINT=
SAGE_DATA_DIR=
SAGE_SET_CHANGE_ADDRESS=false


# ============================================================
# CHIA WALLET (if WALLET_TYPE=chia)
# ============================================================
CHIA_WALLET_RPC_URL=https://localhost:9256
CHIA_WALLET_CERT=
CHIA_WALLET_KEY=
CHIA_FULL_NODE_RPC_URL=https://localhost:8555
CHIA_WALLET_ID_XCH=1
WALLET_FINGERPRINT=
WALLET_DEBUG=false


# ============================================================
# CAT TOKEN
# ============================================================
CAT_ASSET_ID=
CAT_TICKER_ID=
CAT_NAME=MZ
CAT_DECIMALS=3
# CAT_WALLET_ID is auto-detected from the wallet — leave blank unless needed
CAT_WALLET_ID=


# ============================================================
# TRADING CORE
# ============================================================
DRY_RUN=false
ENABLE_BUY=true
ENABLE_SELL=true
LOOP_SECONDS=90
MIN_TRADE_XCH=0.005
MAX_TRADE_XCH=0.050
DEFAULT_TRADE_XCH=0.0275


# ============================================================
# SPREAD & PRICING
# ============================================================
SPREAD_BPS=800
MIN_EDGE_BPS=300
PRICE_STRATEGY=weighted
TIBET_WEIGHT=0.85
ARB_ALERT_THRESHOLD_BPS=200


# ============================================================
# PRICE SAFETY GUARDS
# ============================================================
# Dynamic limits — auto-track market price within ±DYNAMIC_LIMIT_PCT%
# Set to 0 to disable.
DYNAMIC_LIMIT_PCT=50

# Hard limits — absolute backstop (set very wide, e.g. 10x price range)
# Set to 0 to disable. GUI writes HARD_MIN/HARD_MAX_PRICE_XCH.
HARD_MIN_PRICE_XCH=0
HARD_MAX_PRICE_XCH=0
MAX_STEP_CHANGE_FRACTION=0
MAX_MID_MOVE_BPS=500


# ============================================================
# OFFER MANAGEMENT
# ============================================================
MAX_ACTIVE_BUY=25
MAX_ACTIVE_SELL=25
OFFER_EXPIRY_SECS=86400
OFFER_STAGGER_SECS=10
OFFER_REFRESH_BEFORE=1800
FILL_PROTECT_SECS=180


# ============================================================
# REQUOTING
# ============================================================
AUTO_REQUOTE=true
REQUOTE_BPS=150
REQUOTE_COOLDOWN_SECS=60
REQUOTE_BATCH_SIZE=5
REQUOTE_COIN_FREE_WAIT=5


# ============================================================
# RESERVES
# ============================================================
XCH_RESERVE=0.03
CAT_RESERVE=0


# ============================================================
# COIN PREPARATION
# ============================================================
ENABLE_COIN_PREP=false
COIN_PREP_COOLDOWN_SECS=3600
XCH_TARGET_COINS=50
XCH_COIN_SIZE=0.25
CAT_TARGET_COINS=50
CAT_COIN_SIZE=4000
COIN_PREP_MULTIPLIER=1.0
COIN_PREP_HEADROOM_PCT=10
TRANSACTION_FEE_MODE=manual
TRANSACTION_FEE_XCH=0
TRANSACTION_FEE_TARGET_SECS=300
TRANSACTION_FEE_ESTIMATE_COST=20000000
FEE_PREP_COUNT=20
FEE_COIN_SIZE_XCH=0.0001
LADDER_CREATE_PARALLELISM=5
LADDER_CREATE_DELAY_MS=0
LADDER_CREATE_GLOBAL_SERIAL=false


# ============================================================
# ADAPTIVE COIN MANAGEMENT (topup thresholds)
# ============================================================
TOPUP_SLOW_PCT=20
TOPUP_NORMAL_PCT=30
TOPUP_BUSY_PCT=50
FILLS_PER_HOUR_BUSY=10
FILLS_PER_HOUR_SLOW=2
RECONCILE_EVERY_N_LOOPS=2


# ============================================================
# DEXIE INTEGRATION
# ============================================================
DEXIE_API_BASE=https://api.dexie.space
DEXIE_AUTO_POST=true
DEXIE_POST_ENABLED=true
DEXIE_POST_TIMEOUT=15
DEXIE_POST_RETRIES=2
DEXIE_POST_RETRY_SLEEP=1.5
MAX_POSTS_PER_LOOP=30
BOT_TAG=CAT_MM_BOT


# ============================================================
# TIBETSWAP
# ============================================================
TIBET_API_BASE=https://api.v2.tibetswap.io
TIBET_TIMEOUT=10


# ============================================================
# INVENTORY MANAGEMENT (V2)
# ============================================================
INVENTORY_ENABLED=true
SKEW_INTENSITY=0.3
MAX_POSITION_XCH=5.0


# ============================================================
# DYNAMIC SPREADS (V2)
# ============================================================
DYNAMIC_SPREAD_ENABLED=false
BASE_SPREAD_BPS=800
MIN_SPREAD_BPS=300
MAX_SPREAD_BPS=3000
VOLATILITY_WINDOW_HOURS=4
DYNAMIC_FILL_RATE_START_PER_HOUR=4
DYNAMIC_FILL_RATE_FULL_PER_HOUR=12
DYNAMIC_FILL_RATE_MAX_BPS=100


# ============================================================
# TIERED ORDERS (V2)
# ============================================================
TIER_ENABLED=false
BUY_LADDER_REVERSED=false
INNER_SIZE_XCH=1.0
MID_SIZE_XCH=0.5
OUTER_SIZE_XCH=0.25
EXTREME_SIZE_XCH=0.1
INNER_TIER_COUNT=0
MID_TIER_COUNT=0
OUTER_TIER_COUNT=0
EXTREME_TIER_COUNT=0
INNER_TIER_SPARE_COUNT=0
MID_TIER_SPARE_COUNT=0
OUTER_TIER_SPARE_COUNT=0
EXTREME_TIER_SPARE_COUNT=0


# ============================================================
# SNIPER (V2)
# ============================================================
SNIPER_ENABLED=true
SNIPER_SIZE_XCH=0.001
SNIPER_PREP_COUNT=20
SNIPER_EXPIRY_SECS=600
SNIPER_COOLDOWN_SECS=30
SNIPER_CONFIRM_SECS=54
SNIPER_LINGER_SECS=600
SNIPER_POLL_SECS=5
SNIPER_BUFFER_BPS=50
SNIPER_TOP_BOOK_BPS=1
SNIPER_RETRY_BACKOFF_BPS=50
SNIPER_MAIN_BOOK_GUARD_BPS=1
SNIPER_MIN_GAP_BPS=400
SNIPER_REARM_PRICE_MOVE_BPS=100
SNIPER_REARM_GAP_MOVE_BPS=100


# ============================================================
# BOOST / GAP-CLOSE (V2)
# ============================================================
BOOST_SIZE_XCH=0.2
BOOST_EXPIRY_SECS=1800
BOOST_SPREAD_BPS=200
GAP_CLOSE_START_PCT=75
GAP_CLOSE_STEP_PCT=10
GAP_CLOSE_SAFETY_BUFFER_BPS=20
GAP_CLOSE_STEP_COOLDOWN_SECS=60
GAP_CLOSE_CONVERGENCE_SECS=120
GAP_CLOSE_CONVERGENCE_STEP_PCT=20
GAP_CLOSE_CASCADE_WAIT_SECS=60
GAP_CLOSE_CASCADE_BATCH_SIZE=5


# ============================================================
# MARKET INTELLIGENCE (V2)
# ============================================================
COMPETITOR_AWARE_ENABLED=false
OFFERPOOL_ENABLED=false
OFFERPOOL_API_URL=https://offerpool.io/api/v1/offers
DBX_MAX_SPREAD_BPS=500


# ============================================================
# SPLASH P2P NETWORK (V3)
# ============================================================
SPLASH_ENABLED=false
SPLASH_SUBMIT_URL=http://localhost:4000
SPLASH_POST_RETRIES=2
SPLASH_POST_TIMEOUT=15
SPLASH_POST_RETRY_SLEEP=1.5
SPLASH_RECEIVE_ENABLED=true
SPLASH_RECEIVE_POLL_SECS=5
SPLASH_RECEIVE_BATCH_SIZE=10
# Path to splash.exe — leave blank to use the one bundled alongside the app
SPLASH_BINARY_PATH=
SPLASH_P2P_PORT=11511
SPLASH_AUTO_START=true
SPLASH_TESTNET=false


# ============================================================
# COIN SELECTION (V3)
# ============================================================
COIN_IDS_ENABLED=true


# ============================================================
# COINSET API (V3 — fast cloud coin queries)
# ============================================================
COINSET_ENABLED=true
COINSET_API_URL=https://api.coinset.org
COINSET_TIMEOUT=5
COINSET_FALLBACK_WALLET=true


# ============================================================
# SPACESCAN (V4 — on-chain verification)
# ============================================================
SPACESCAN_ENABLED=true
# Get a free API key at https://spacescan.io/
SPACESCAN_API_KEY=
SPACESCAN_PRO_URL=https://pro-api.spacescan.io
SPACESCAN_FREE_URL=https://api.spacescan.io
SPACESCAN_TIMEOUT=10
SPACESCAN_BALANCE_CHECK_EVERY_N=10
SPACESCAN_BALANCE_THRESHOLD_XCH=0.1


# ============================================================
# RUNTIME MONITOR
# ============================================================
RUNTIME_MONITOR_ENABLED=true
RUNTIME_MONITOR_POLL_SECS=20
RUNTIME_MONITOR_DEXIE_GRACE_SECS=120
RUNTIME_MONITOR_TOPUP_WARN_SECS=900
RUNTIME_MONITOR_STALE_POLLS=2
WALLET_STALE_CREATE_LIMIT=3


# ============================================================
# RUNTIME FEATURES
# ============================================================
ENABLE_RUNTIME_COIN_HEALTH=false

# ============================================================
# UPDATE CHECK
# ============================================================
# URL the app polls (cached for 6h) to see if a newer release is published.
# Must be a GitHub-style releases endpoint returning {"tag_name": ..., "html_url": ...}.
# Leave blank to disable the update banner entirely.
# Example (set once you publish releases):
#   RELEASES_API_URL=https://api.github.com/repos/MonkeyZoo/chia-market-maker/releases/latest
RELEASES_API_URL=
