# ============================================================
# CATalyst — .gitignore
# Review before every commit. If it's not here, it might go up.
# ============================================================

# --- Secrets & environment ---
.env
.env.*
!.env.example
user_secrets.json
secrets.json

# --- SSL / TLS certs and keys (Sage wallet mTLS) ---
sage_client_ssl/
*.key
*.pem
*.crt
*.cert
*.p12
*.pfx

# --- Live databases ---
*.db
*.db-shm
*.db-wal
*.sqlite
bot_backup_*.db
bot_backup_*/
tmp_db_*

# --- E2E test isolated data dir (per-session DB + state) ---
.e2e_data/
tests/.e2e_data/

# --- Log files ---
*.log
coin_prep_output.log
bot_superlog_*.log
crash.log

# --- Runtime archive files ---
superlog_archive.jsonl

# --- Runtime state files (regenerated on start) ---
coin_prep_status.json
coin_prep_last.json
designation_debug.json
worker_cancelled_ids.json
.fresh_start_chosen
*.tmp
*.temp

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
*.egg

# --- Alternate build output directories ---
build2/
dist2/

# --- Runtime test/state files ---
smoke_test_state.json

# --- Backup and archive directories (large, no public value) ---
_backups/
_archive/
backups_pre_*/

# --- OS / editor junk ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/settings.json
*.iml

# --- PyInstaller build output ---
*.spec
dist/
build/

# --- Compiled binaries (not suitable for source repo) ---
# splash.exe ships as a separate download, not via git
splash.exe
splash.exe.bak
*.exe
*.exe.bak

# --- Claude Code local settings (contains session tokens + wallet fingerprints) ---
.claude/settings.local.json
.claude/launch.json
.claude/projects/
CLAUDE.md

# --- Misc ---
tmp_greenfloor_review/

# --- Dev-only files (stay local) ---
tools/
website
website screenshots/
simulation/
# Personal launcher with hardcoded paths — not useful off the dev machine
CATalyst.vbs
!catalyst.spec
!splash.html

# --- Local scratch / debug scripts (not for commit) ---
check_dexie.py
check_status.py
check_thresholds.py
config_live.py
qdb*.py
restart_after_coinprep.py
scripts/snapshot_gui.py
shutdown_bot.py
start_bot.py
test_prep.py
trigger_coin_prep.py
wait_for_bot.py
/null
version_info.txt
.playwright-cli/
outputs/
capture_screenshots.py

# --- Claude Code agent scratch ---
.claude/

# --- Codex / local agent instructions and skills ---
.agents/
AGENTS.md

# --- Internal dev notes (stay local, kept out of GitHub) ---
# Claude-session handoff prompts, internal audit plans, and other
# material that would confuse external contributors or leak workflow
# details.  Files still exist on disk; they just aren't tracked.
NEXT_SESSION.md
tests/master_test_plan/
docs/COIN_FSM_DESIGN.md
docs/tech_debt.md

